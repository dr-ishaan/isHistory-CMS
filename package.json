{
  "name": "astro-cms-obsidian-plugin",
  "version": "1.5.0",
  "description": "CMS for Astro sites to manage file collections with live frontmatter schema validation and automated publishing workflows.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "build:check": "node build.mjs",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dr-ishaan/astro-cms-obsidian-plugin.git"
  },
  "keywords": [
    "obsidian",
    "astro",
    "cms",
    "frontmatter",
    "validation"
  ],
  "author": "Ishhan",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/dr-ishaan/astro-cms-obsidian-plugin/issues"
  },
  "homepage": "https://github.com/dr-ishaan/astro-cms-obsidian-plugin#readme",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "builtin-modules": "^5.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-plugin-obsidian": "^2.31.0",
    "obsidian": "^1.13.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
